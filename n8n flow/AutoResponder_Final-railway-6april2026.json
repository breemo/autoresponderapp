    {
      "parameters": {
        "jsCode": "const base = $items(\"Code in JavaScript1\", 0, 0)[0].json;\nconst integration = $items(\"client_feature\", 0, 0)[0].json;\nconst decision = $node[\"message_decision\"].json;\n\nfunction generateUuid() {\n  return 'xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx'.replace(/[xy]/g, function(c) {\n    const r = Math.random() * 16 | 0;\n    const v = c === 'x' ? r : (r & 0x3 | 0x8);\n    return v.toString(16);\n  });\n}\n\n//const stateItems = $items(\"get_conversation_state\", 0, 0) || [];\n//const state = stateItems.length > 0 ? stateItems[0].json : null;\n\n//const conversationId = state?.conversation_id || generateUuid();\nconst conversationId = $node[\"prepare_conversation\"].json[\"conversation_id\"];\nconst intent = $json.intent || null;\n\n// 0) إذا المستخدم بمرحلة إرسال بيانات التواصل\nif (decision.message_action === \"handle_contact\") {\n  return [\n    {\n      json: {\n        platform: base.platform,\n        channelKey: base.channelKey,\n        text: base.text,\n        sender_id: base.sender_id,\n        client_id: integration.client_id,\n        config: integration.config || {},\n        reply_text: decision.reply_text,\n        next_step: null,\n        conversation_status: \"active\",\n        conversation_id: conversationId\n      }\n    }\n  ];\n}\n\n// 1) إذا AI قال إن المحادثة انتهت\nif (intent === \"closing\") {\n  return [\n    {\n      json: {\n        platform: base.platform,\n        channelKey: base.channelKey,\n        text: base.text,\n        sender_id: base.sender_id,\n        client_id: integration.client_id,\n        config: integration.config || {},\n        reply_text: \"أهلاً وسهلاً 🙏 إذا احتجت أي شيء أنا موجود.\",\n        next_step: null,\n        conversation_status: \"closed\",\n        conversation_id: conversationId\n      }\n    }\n  ];\n}\n\n// 2) إذا AI فهم أنه طلب\nif (intent === \"order\") {\n  return [\n    {\n      json: {\n        platform: base.platform,\n        channelKey: base.channelKey,\n        text: base.text,\n        sender_id: base.sender_id,\n        client_id: integration.client_id,\n        config: integration.config || {},\n        reply_text: \"ممتاز 👌 خلينا نبدأ الطلب 🙏 ممكن تبعتلي اسمك ورقمك للتواصل؟\",\n        lead_step: \"ask_contact\",\n        next_step: \"ask_contact\",\n        conversation_status: \"active\",\n        conversation_id: conversationId\n      }\n    }\n  ];\n}\n\n// 3) إذا message_decision قررت إنهاء المحادثة\nif (decision.message_action === \"end_conversation\") {\n  return [\n    {\n      json: {\n        platform: base.platform,\n        channelKey: base.channelKey,\n        text: base.text,\n        sender_id: base.sender_id,\n        client_id: integration.client_id,\n        config: integration.config || {},\n        reply_text: decision.reply_text,\n        next_step: null,\n        conversation_status: \"closed\",\n        conversation_id: conversationId\n      }\n    }\n  ];\n}\n\n// 4) الوضع العادي\nlet replyText = $json.reply_text;\n\nif (!replyText) {\n  replyText = \"شكراً لتواصلك معنا 🙏 سيتم الرد عليك بأقرب وقت ممكن\";\n}\n\nreturn [\n  {\n    json: {\n      platform: base.platform,\n      channelKey: base.channelKey,\n      text: base.text,\n      sender_id: base.sender_id,\n      client_id: integration.client_id,\n      config: integration.config || {},\n      reply_text: replyText,\n      next_step: null,\n      conversation_status: \"active\",\n      conversation_id: conversationId\n    }\n  }\n];"
      },
