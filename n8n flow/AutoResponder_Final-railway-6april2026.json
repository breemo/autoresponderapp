    {
      "parameters": {
        "jsCode": "const base = $items(\"Code in JavaScript1\", 0, 0)[0].json;\nconst integration = $items(\"client_feature\", 0, 0)[0].json;\n\nlet aiRaw =\n  $json.choices?.[0]?.message?.content ||\n  '{\"reply\":\"عذرًا، لم أتمكن من إنشاء رد الآن.\",\"intent\":\"unknown\"}';\n\n// نحاول نفك JSON\nlet parsed;\n\ntry {\n  parsed = JSON.parse(aiRaw);\n} catch (e) {\n  parsed = {\n    reply: aiRaw,\n    intent: \"unknown\"\n  };\n}\n\nconst replyText = parsed.reply || \"عذرًا، لم أتمكن من إنشاء رد الآن.\";\nconst intent = parsed.intent || \"unknown\";\n\nreturn [\n  {\n    json: {\n      platform: base.platform,\n      channelKey: base.channelKey,\n      text: base.text,\n      sender_id: base.sender_id,\n      client_id: integration.client_id,\n      config: integration.config || {},\n      reply_text: replyText,\n      intent: intent\n    }\n  }\n];"
      },
