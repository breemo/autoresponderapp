    {
      "parameters": {
        "jsCode": "const platform = String($json.params?.platform || \"\").toLowerCase();\nconst channelKey = String($json.params?.channelKey || \"\");\n\nlet text = \"\";\nlet sender_id = \"\";\n\nif (platform === \"telegram\") {\n  text = $json.body?.message?.text || \"\";\n  sender_id = String($json.body?.message?.chat?.id || \"\");\n}\n\nif (platform === \"facebook\") {\n  const fbMessage = $json.body?.entry?.[0]?.messaging?.[0];\n  text = fbMessage?.message?.text || \"\";\n  sender_id = String(fbMessage?.sender?.id || \"\");\n}\n\nreturn {\n  platform,\n  channelKey,\n  text,\n  sender_id,\n  raw_body: $json.body || $json\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -1968,
        80
      ],
      "id": "0b193b7b-7cbf-4033-9aed-1b29b22b5acf",
      "name": "Code in JavaScript1"
    },
    {
      "parameters": {
        "jsCode": "const base = $items(\"Code in JavaScript1\", 0, 0)[0].json;\nconst integration = $items(\"client_feature\", 0, 0)[0].json;\nconst replies = $input.all().map(item => item.json);\nconst text = String(base.text || \"\").toLowerCase().trim();\n\n// fallback default reply\nlet selectedReply = \"شكراً لتواصلك معنا 🙏 سيتم الرد عليك بأقرب وقت ممكن\";\n\nfor (const r of replies) {\n  const trigger = String(r.trigger_text || \"\").toLowerCase().trim();\n  if (trigger && text.includes(trigger)) {\n    selectedReply = r.reply_text;\n    break;\n  }\n}\n\nreturn [\n  {\n    json: {\n      platform: base.platform,\n      channelKey: base.channelKey,\n      text: base.text,\n      sender_id: base.sender_id,\n      client_id: integration.client_id,\n      config: integration.config || {},\n      reply_text: selectedReply\n    }\n  }\n];"
      },
