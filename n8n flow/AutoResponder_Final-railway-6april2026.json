    {
      "parameters": {
        "jsCode": "const base = $items(\"Code in JavaScript1\", 0, 0)[0].json;\nconst integration = $items(\"client_feature\", 0, 0)[0].json;\n\n// state من الداتابيز\n//const stateItem = $items(\"get_conversation_state\", 0, 0)[0];\n//const state = stateItem ? stateItem.json : null;\n\nconst stateItems = $items(\"get_conversation_state\", 0, 0) || [];\nconst state = stateItems.length > 0 ? stateItems[0].json : null;\n\n\nconst currentStep = state?.current_step || null;\n\nconst text = String(base.text || \"\").toLowerCase().trim();\n\n// كلمات إنهاء المحادثة\nconst endWords = [\n  \"شكرا\",\n  \"شكراً\",\n  \"يسلمو\",\n  \"يعطيك العافية\",\n  \"تمام\",\n  \"خلص\",\n  \"خلص شكرا\",\n  \"اوك شكرا\",\n  \"ممتاز شكرا\"\n];\n\nconst isEndConversation = endWords.some(word => text.includes(word));\n\n// 🟢 1. إذا المستخدم كان بمرحلة الطلب\nif (currentStep === \"ask_contact\") {\n  return [\n    {\n      json: {\n        platform: base.platform,\n        channelKey: base.channelKey,\n        text: base.text,\n        sender_id: base.sender_id,\n        client_id: integration.client_id,\n        config: integration.config || {},\n        message_action: \"handle_contact\",\n        reply_text: \"تمام 👌 تم استلام بياناتك، رح نتواصل معك قريبًا 🙏\"\n      }\n    }\n  ];\n}\n\n// 🔴 2. إنهاء المحادثة\nif (isEndConversation) {\n  return [\n    {\n      json: {\n        platform: base.platform,\n        channelKey: base.channelKey,\n        text: base.text,\n        sender_id: base.sender_id,\n        client_id: integration.client_id,\n        config: integration.config || {},\n        message_action: \"end_conversation\",\n        reply_text: \"أهلاً وسهلاً 🙏 إذا احتجت أي شيء أنا موجود.\"\n      }\n    }\n  ];\n}\n\n// 🟡 3. الوضع الطبيعي\nreturn [\n  {\n    json: {\n      platform: base.platform,\n      channelKey: base.channelKey,\n      text: base.text,\n      sender_id: base.sender_id,\n      client_id: integration.client_id,\n      config: integration.config || {},\n      message_action: \"continue\",\n      reply_text: \"\"\n    }\n  }\n];"
      },
