          "parameters": [
            {
              "name": "Authorization",
              "value": "=Bearer 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"
