    {
      "parameters": {
        "jsCode": "const config = $node[\"ai_feature_config\"].json[\"config\"] || {};\n\nconst business_name = config.business_name || \"\";\nconst business_description = config.business_description || \"\";\nconst reply_tone = config.reply_tone || \"friendly\";\nconst language = config.language || \"ar\";\nconst working_hours = config.working_hours || \"\";\nconst special_instructions = config.special_instructions || \"\";\n\nconst userMessage = $node[\"Code in JavaScript1\"].json[\"text\"] || \"\";\n\n// آخر الرسائل من الداتابيز\nconst historyItems = $items(\"get_conversation_history\", 0, 0);\n\n// Supabase رجّع الأحدث أولًا، بدنا نقلبهم عشان يصيروا من الأقدم للأحدث\nconst orderedHistory = [...historyItems].reverse();\n\nconst conversationHistory = orderedHistory\n  .map(item => {\n    const direction = item.json.direction === \"outbound\" ? \"Bot\" : \"User\";\n    const message = item.json.message || \"\";\n    return `${direction}: ${message}`;\n  })\n  .join(\"\\n\");\n\nconst prompt = `\nYou are an AI assistant for ${business_name}.\n\nBusiness description:\n${business_description}\n\nReply tone: ${reply_tone}\nLanguage: ${language}\n\nWorking hours:\n${working_hours}\n\nInstructions:\n${special_instructions}\n\nKeep answers short and direct.\nKeep replies under 2 sentences unless necessary.\nDo NOT include \"Bot:\" or \"User:\" in your reply. Just answer naturally.\n\nConversation history:\n${conversationHistory}\n\nCurrent user message:\n${userMessage}\n\nReply to the user based on the conversation.\n\nIMPORTANT:\nReturn your response ONLY as valid JSON in the following format:\n\n{\n  \"reply\": \"your reply message here\",\n  \"intent\": \"one of: greeting, pricing, order, support, closing, unknown\"\n}\n\nRules:\n- Do NOT include any extra text outside the JSON\n- Do NOT include \"Bot:\" or \"User:\"\n- Keep the reply natural, friendly, and short\n`;\n\nreturn [{\n  json: {\n    prompt\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        544,
        -64
      ],
